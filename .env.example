# =============================================================================
# ANVIL — environment variables (example)
# =============================================================================
#
# Copy this file to `.env` (gitignored) and edit. Anvil itself does NOT
# auto-load `.env` — your shell does (or `direnv`, or `python-dotenv` if
# you wire it in your script). The vars below are read directly from
# `os.environ` in the modules listed in the column.
#
# Two principles:
#   1. EVERY default is documented. Everything ANVIL reads from the
#      environment is listed here — there are no hidden flags.
#   2. EVERY secret is gitignored. Never commit a populated `.env`.
#
# =============================================================================
# Inference backend selection
# =============================================================================
#
# `ANVIL_LLM_BACKEND` chooses which LLM gets called. Recognized values:
#
#   fake               (default) FakeLLMBackend — deterministic, no
#                      network, no key. Logs a WARNING on selection.
#                      Used by CI and the offline demo. Never use in
#                      production.
#   nvidia_nim         OpenAI-compatible call against NVIDIA NIM
#                      (build.nvidia.com). Free tier: 40 req/min,
#                      ~1k credits on signup, request up to 5k.
#                      Requires NVIDIA_API_KEY.
#   openai_compatible  Any OpenAI-protocol endpoint (Together, Fireworks,
#                      vLLM, Ollama, LM Studio, ...). Requires
#                      OPENAI_COMPAT_BASE_URL + OPENAI_COMPAT_API_KEY +
#                      ANVIL_LLM_MODEL.
#   instructor         instructor.from_provider — full provider catalog
#                      (openai/, anthropic/, google/, ...). Requires
#                      ANVIL_LLM_MODEL in `<provider>/<model>` form +
#                      the provider's own native env var (OPENAI_API_KEY,
#                      ANTHROPIC_API_KEY, etc.).
#
# Anvil refuses to silently coerce typos: any unrecognized value raises
# at startup.

ANVIL_LLM_BACKEND=fake
# ANVIL_LLM_BACKEND=nvidia_nim
# ANVIL_LLM_BACKEND=openai_compatible
# ANVIL_LLM_BACKEND=instructor


# =============================================================================
# NVIDIA NIM (build.nvidia.com)
# =============================================================================
#
# NIM is OpenAI-Chat-Completions-compatible behind
# `https://integrate.api.nvidia.com/v1`. Sign up at build.nvidia.com,
# join the NVIDIA Developer Program, generate a key prefixed `nvapi-`.
#
# Locked model catalog — see `src/anvil/generation/nim_health.py`
# (live-probed 2026-04-25). Each picks a different design-space corner
# so the eval table reads as a real comparison:
#
#   meta/llama-3.3-70b-instruct                ← default; Meta family, no reasoning
#   nvidia/llama-3.3-nemotron-super-49b-v1.5   ← NVIDIA-RLHF, reasoning-capable
#   openai/gpt-oss-120b                        ← OpenAI open-weight 120b
#
# `anvil nim-check` probes all three sequentially and reports
# reachability + latency + token usage — run it first to confirm your
# key + the catalog before launching an eval matrix. Add `--list` to
# also fetch the live `/v1/models` and surface catalog drift.

# REQUIRED for nvidia_nim backend:
# NVIDIA_API_KEY=nvapi-REPLACE-ME-paste-key-from-build.nvidia.com

# Override the default model (see catalog above). Defaults to
# `meta/llama-3.3-70b-instruct` — the first key of NIM_MODELS.
# ANVIL_LLM_MODEL=meta/llama-3.3-70b-instruct
# ANVIL_LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
# ANVIL_LLM_MODEL=openai/gpt-oss-120b

# Override the base URL — useful if you self-host NIM containers.
# Default: https://integrate.api.nvidia.com/v1
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Reasoning-mode passthroughs. Forwarded to NIM's
# `chat_template_kwargs.thinking` extra_body. Harmless for models that
# ignore the kwarg (e.g. Llama-3.3); meaningful for DeepSeek v3.1+.
# ANVIL_NIM_REASONING=1
# ANVIL_NIM_REASONING_EFFORT=high

# Per-request timeout for OpenAI-compatible LLM calls, including NIM.
# Default: 120 seconds.
# ANVIL_LLM_TIMEOUT_S=120


# =============================================================================
# Generic OpenAI-compatible endpoint
# =============================================================================
#
# Use `ANVIL_LLM_BACKEND=openai_compatible` for any provider that exposes
# the OpenAI Chat Completions schema at a custom base URL. Examples:
#
#   Together     base_url=https://api.together.xyz/v1
#   Fireworks    base_url=https://api.fireworks.ai/inference/v1
#   vLLM (self)  base_url=http://localhost:8000/v1
#   Ollama       base_url=http://localhost:11434/v1
#   LM Studio    base_url=http://localhost:1234/v1
#
# Anvil treats `openai_compatible` and `nvidia_nim` as different backends
# in the run-logger manifest, so a switch is auditable.

# OPENAI_COMPAT_BASE_URL=https://api.together.xyz/v1
# OPENAI_COMPAT_API_KEY=
# ANVIL_LLM_MODEL=deepseek-ai/deepseek-v3


# =============================================================================
# instructor.from_provider (Anthropic / OpenAI native / Google / ...)
# =============================================================================
#
# Use `ANVIL_LLM_BACKEND=instructor` and a `<provider>/<model>` ID. The
# provider's native env var (NOT a custom one) is what supplies the key.

# Examples — pick one and uncomment:
# ANVIL_LLM_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=sk-...

# ANVIL_LLM_MODEL=anthropic/claude-3-5-sonnet-latest
# ANTHROPIC_API_KEY=sk-ant-...

# ANVIL_LLM_MODEL=google/gemini-1.5-pro
# GOOGLE_API_KEY=...


# =============================================================================
# Embedding backend
# =============================================================================
#
# `ANVIL_EMBEDDER` chooses which embedder generates dense vectors for
# the vector store. Recognized values:
#
#   hash                  (default) DeterministicHashEmbedder.
#                         Lexical-only, no semantic quality. Used by
#                         CI/tests. Logs a WARNING on selection.
#   sentence_transformer  SentenceTransformer (BAAI/bge-small-en-v1.5
#                         by default). First call downloads ~130 MB of
#                         model weights — set ANVIL_ST_CACHE_DIR if you
#                         want them somewhere other than `~/.cache`.

# ANVIL_EMBEDDER=sentence_transformer
# ANVIL_ST_MODEL=BAAI/bge-small-en-v1.5
# ANVIL_ST_CACHE_DIR=~/.cache/anvil/sentence-transformers


# =============================================================================
# Logging
# =============================================================================
#
# `ANVIL_ENV=production` switches structlog from the dev console
# renderer to JSONRenderer (one JSON object per line, suitable for log
# aggregators). Logs always go to stderr — stdout is reserved for
# machine-readable output of `anvil ... --json`.

# ANVIL_ENV=production


# =============================================================================
# Optional integrations (parser benchmark, M7)
# =============================================================================

# Reducto (PDF parsing) — free tier available at https://reducto.ai
# REDUCTO_API_KEY=

# Azure Document Intelligence — free tier available
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
# AZURE_DOCUMENT_INTELLIGENCE_KEY=
